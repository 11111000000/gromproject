---
import Base from '../layouts/Base.astro';
import ProductImage from '../components/ProductImage.astro';
import { t, defaultLang, type Lang } from '../i18n/translations';

const lang = (Astro.url.searchParams.get('lang') as Lang) || defaultLang;
const tr = t[lang];

const products: Record<Lang, Array<{sku: string; name: string; price: number; rating: number | null; reviews: number; badge: string | null; short: string; category: string}>> = {
  ru: [
    { sku: '001', name: 'Озёрные коньки «ГРОМ» неокрашенные', price: 7800, rating: 5.0, reviews: 109, badge: 'ХИТ', short: 'Сталь 420 · 460/520 мм · 1.3 кг', category: 'finished' },
    { sku: '002', name: 'Озёрные коньки «ГРОМ» окрашенные', price: 9200, rating: 5.0, reviews: 109, badge: 'ХИТ', short: 'Антикоррозийное покрытие', category: 'finished' },
    { sku: '003', name: 'Лезвие «ГРОМ» неокрашенное', price: 6600, rating: null, reviews: 0, badge: null, short: '480/520 мм · 1.1 кг', category: 'blades' },
    { sku: '004', name: 'Лезвие «ГРОМ» окрашенное', price: 8000, rating: null, reviews: 0, badge: null, short: 'Защитное покрытие', category: 'blades' },
    { sku: '005', name: 'Чехол для коньков (байсов)', price: 1200, rating: null, reviews: 0, badge: 'ХИТ', short: 'Мебельная ткань с ворсом', category: 'accessories' },
    { sku: '006', name: 'Механическое крепление (SNS/NNN)', price: 1200, rating: null, reviews: 0, badge: null, short: 'Металлические несущие', category: 'accessories' },
  ],
  en: [
    { sku: '001', name: 'GROM Lake Skates Unpainted', price: 7800, rating: 5.0, reviews: 109, badge: 'HIT', short: 'Steel 420 · 460/520 mm · 1.3 kg', category: 'finished' },
    { sku: '002', name: 'GROM Lake Skates Painted', price: 9200, rating: 5.0, reviews: 109, badge: 'HIT', short: 'Anti-corrosion coating', category: 'finished' },
    { sku: '003', name: 'GROM Blade Unpainted', price: 6600, rating: null, reviews: 0, badge: null, short: '480/520 mm · 1.1 kg', category: 'blades' },
    { sku: '004', name: 'GROM Blade Painted', price: 8000, rating: null, reviews: 0, badge: null, short: 'Protective coating', category: 'blades' },
    { sku: '005', name: 'Skate Bag', price: 1200, rating: null, reviews: 0, badge: 'HIT', short: 'Velvet furniture fabric', category: 'accessories' },
    { sku: '006', name: 'Mechanical Binding (SNS/NNN)', price: 1200, rating: null, reviews: 0, badge: null, short: 'Metal supports', category: 'accessories' },
  ],
  zh: [
    { sku: '001', name: 'GROM 湖上冰鞋 未涂装', price: 7800, rating: 5.0, reviews: 109, badge: '热卖', short: '420不锈钢 · 460/520毫米 · 1.3公斤', category: 'finished' },
    { sku: '002', name: 'GROM 湖上冰鞋 已涂装', price: 9200, rating: 5.0, reviews: 109, badge: '热卖', short: '防腐涂层', category: 'finished' },
    { sku: '003', name: 'GROM 冰刀 未涂装', price: 6600, rating: null, reviews: 0, badge: null, short: '480/520毫米 · 1.1公斤', category: 'blades' },
    { sku: '004', name: 'GROM 冰刀 已涂装', price: 8000, rating: null, reviews: 0, badge: null, short: '保护涂层', category: 'blades' },
    { sku: '005', name: '冰刀收纳袋', price: 1200, rating: null, reviews: 0, badge: '热卖', short: '绒面家具布料', category: 'accessories' },
    { sku: '006', name: '机械绑定 (SNS/NNN)', price: 1200, rating: null, reviews: 0, badge: null, short: '金属支架', category: 'accessories' },
  ],
};

const reviewsLabel: Record<Lang, string> = {
  ru: '★ {rating} · {count} отзывов',
  en: '★ {rating} · {count} reviews',
  zh: '★ {rating} · {count}条评价',
};
---
<Base title={tr.catalog_page_title} description={lang === 'ru' ? 'Каталог озёрных коньков ГРОМ — 6 моделей: готовые коньки, лезвия, аксессуары.' : lang === 'en' ? 'GROM lake skate catalog — 6 models: complete skates, blades, accessories.' : 'ГРОМ 冰刀目录 — 6款型号：成品冰刀、刀片、配件。'}>

  <!-- Schema.org BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": lang === 'ru' ? 'Главная' : lang === 'en' ? 'Home' : '首页', "item": "https://11111000000.github.io/gromproject/" },
      { "@type": "ListItem", "position": 2, "name": lang === 'ru' ? 'Каталог' : lang === 'en' ? 'Catalog' : '目录', "item": "https://11111000000.github.io/gromproject/catalog/" }
    ]
  })} />

  <section class="relative bg-thunder text-frost py-16 overflow-hidden border-b-4 border-bolt">
    <div class="absolute inset-0 bg-ice-texture opacity-90"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="section-label justify-center mb-3">{tr.catalog_label}</div>
      <h1 class="font-display font-black uppercase leading-[0.95] text-4xl sm:text-6xl lg:text-7xl mb-6">{tr.catalog_h1}</h1>
    </div>
  </section>

  <section class="bg-frost ice-cracks-bg py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="sr-only">{tr.catalog_h1}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {products[lang].map(p => (
          <a href={`${import.meta.env.BASE_URL}product/${p.sku}`} class="product-card group block">
            {p.badge && <span class="badge-bolt absolute top-3 right-3 z-10">{p.badge}</span>}
            <div class="aspect-square bg-thunder overflow-hidden flex items-center justify-center relative">
              <ProductImage sku={p.sku} name={p.name} class="absolute inset-0" />
            </div>
            <div class="p-5">
              <div class="text-[10px] font-mono uppercase tracking-industrial text-frost-dark/50 mb-1"><span>{tr.article}</span> <span>{p.sku}</span></div>
              <h3 class="font-display font-bold text-thunder leading-snug mb-2">{p.name}</h3>
              <p class="text-frost-dark/60 text-sm mb-4">{p.short}</p>
              {p.reviews > 0 && <div class="text-bolt text-xs font-mono mb-3">{reviewsLabel[lang].replace('{rating}', String(p.rating)).replace('{count}', String(p.reviews))}</div>}
              <div class="flex items-end justify-between pt-4 border-t border-frost-dark">
                <span class="font-display font-black text-thunder text-2xl">{p.price.toLocaleString('ru-RU')} ₽</span>
                <span class="text-bolt font-black text-xs uppercase tracking-industrial">→</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>