---
import Base from '../../layouts/Base.astro';
import ProductImage from '../../components/ProductImage.astro';
import { t, defaultLang, type Lang } from '../../i18n/translations';

const lang = (Astro.url.searchParams.get('lang') as Lang) || defaultLang;
const tr = t[lang];

export function getStaticPaths() {
  return [
    { params: { sku: '001' } }, { params: { sku: '002' } },
    { params: { sku: '003' } }, { params: { sku: '004' } },
    { params: { sku: '005' } }, { params: { sku: '006' } },
  ];
}

interface Spec { k: string; v: string; }
interface Product {
  name: string;
  price: number; sku: string; rating: number | null; reviews: number; badge: string | null;
  short: string; desc: string;
  specs: Spec[];
  variants?: { size?: string[]; binding?: string[]; };
}

const products: Record<Lang, Record<string, Product>> = {
  ru: {
    '001': { sku: '001', name: t.ru.product_001_name, price: 7800, rating: 5.0, reviews: 109, badge: t.ru.product_badge_hit, short: 'Сталь 420 · 460/520 мм · 1.3 кг · HRC 50', desc: 'Нордики или как их ещё называют — байсы. Коньки для открытого льда собственной разработки и исполнения, предназначены под эксплуатацию с ботинками беговых лыж для конькового хода. Эти коньки — результат долгой и кропотливой работы, как в теоретической части так и в практическом исполнении.', specs: [
      { k: 'HRC (твёрдость)', v: '50' }, { k: 'Сталь', v: '420 нержавеющая, 1.2 мм' }, { k: 'Корпус', v: 'Алюминиевый уголок 20×20×2 мм' }, { k: 'Клёпки', v: 'Полнотелые алюминиевые' }, { k: 'Длина', v: '460 мм / 520 мм' }, { k: 'Вес пары', v: '800 г (460 мм) / 880 г (520 мм)' }, { k: 'Вес с упаковкой', v: '1,3 кг' }, { k: 'Макс. нагрузка', v: 'до 110 кг (усиленные — под заказ)' }, { k: 'Полка под крепление', v: '42 мм' }, { k: 'Радиус поворота', v: '4 м (460 мм) / 7 м (520 мм)' }, { k: 'Ресурс заточки', v: '≥ 200 км на чистом льду' }, { k: 'Производство', v: 'Лазерная резка на ЧПУ' }, { k: 'Совместимость', v: 'NNN, SNS, Prolink' },
      { k: 'Мастер', v: 'Алексей' }, { k: 'Серийный №', v: 'ГРОМ-001-2026-####' }, { k: 'Гарантия', v: '1 год' }, { k: 'Срок изготовления', v: '2 недели' },
    ], variants: { size: ['460 мм', '520 мм'], binding: ['NNN', 'SNS'] } },
    '002': { sku: '002', name: t.ru.product_002_name, price: 9200, rating: 5.0, reviews: 109, badge: t.ru.product_badge_hit, short: 'Антикоррозийное покрытие · сталь 420 · 460/520 мм · HRC 50', desc: 'Премиум-версия с порошковым антикоррозийным покрытием. Та же надёжность, что у неокрашенных, плюс защита от ржавчины и стильный внешний вид.', specs: [
      { k: 'HRC (твёрдость)', v: '50' }, { k: 'Сталь', v: '420 нержавеющая, 1.2 мм' }, { k: 'Покрытие', v: 'Порошковая окраска' }, { k: 'Длина', v: '460 мм / 520 мм' }, { k: 'Вес пары', v: '800 г (460 мм) / 880 г (520 мм)' }, { k: 'Вес с упаковкой', v: '1,3 кг' }, { k: 'Макс. нагрузка', v: 'до 110 кг' }, { k: 'Ресурс заточки', v: '≥ 200 км' },
      { k: 'Мастер', v: 'Алексей' }, { k: 'Серийный №', v: 'ГРОМ-002-2026-####' }, { k: 'Гарантия', v: '1 год' },
    ], variants: { size: ['460 мм', '520 мм'], binding: ['NNN', 'SNS'] } },
    '003': { sku: '003', name: t.ru.product_003_name, price: 6600, rating: null, reviews: 0, badge: null, short: '480/520 мм · 1.1 кг · HRC 50', desc: 'Стальное лезвие для открытого льда. Подходит для самостоятельной установки на лыжные ботинки NNN и SNS.', specs: [
      { k: 'HRC (твёрдость)', v: '50' }, { k: 'Материал', v: 'Сталь' }, { k: 'Длина', v: '480 мм / 520 мм' }, { k: 'Вес', v: '1,1 кг' }, { k: 'Совместимость', v: 'NNN, SNS' },
      { k: 'Мастер', v: 'Алексей' }, { k: 'Серийный №', v: 'ГРОМ-003-2026-####' }, { k: 'Гарантия', v: '1 год' },
    ], variants: { size: ['480 мм', '520 мм'] } },
    '004': { sku: '004', name: t.ru.product_004_name, price: 8000, rating: null, reviews: 0, badge: null, short: 'Защитное покрытие · 480/520 мм · HRC 50', desc: 'Лезвие с антикоррозийным покрытием. Увеличенный срок службы, защита от ржавчины.', specs: [
      { k: 'HRC (твёрдость)', v: '50' }, { k: 'Материал', v: 'Сталь' }, { k: 'Покрытие', v: 'Порошковая окраска' }, { k: 'Длина', v: '480 мм / 520 мм' }, { k: 'Вес', v: '1,1 кг' }, { k: 'Совместимость', v: 'NNN, SNS' },
      { k: 'Мастер', v: 'Алексей' }, { k: 'Серийный №', v: 'ГРОМ-004-2026-####' }, { k: 'Гарантия', v: '1 год' },
    ], variants: { size: ['480 мм', '520 мм'] } },
    '005': { sku: '005', name: t.ru.product_005_name, price: 1200, rating: null, reviews: 0, badge: t.ru.product_badge_hit, short: 'Плотная мебельная ткань с ворсом', desc: 'Чехол выполнен из плотной мебельной ткани с мягким и приятным ворсом. В нём очень удобно хранить и транспортировать озёрные коньки как нашего производства, так и модели сторонних производителей.', specs: [
      { k: 'Материал', v: 'Мебельная ткань с ворсом' }, { k: 'Вес', v: '0,1 кг' }, { k: 'Назначение', v: 'Хранение и транспортировка' },
