    '006': { sku: '006', name: t.ru.product_006_name, price: 1200, rating: null, reviews: 0, badge: null, short: 'Металлические несущие · SNS/NNN · 0,35 кг', desc: 'Несущие детали головной части крепления выполнены из металла, что повышает его надёжность по сравнению с полностью пластиковыми аналогами.', specs: [
      { k: 'Материал несущих', v: 'Металл' }, { k: 'Тип', v: 'Монолитная пластина' }, { k: 'Вес', v: '0,35 кг' }, { k: 'Совместимость', v: 'NNN, SNS, Prolink' },
    ], variants: { binding: ['NNN', 'SNS'] } },
  },
  en: {
    '001': { sku: '001', name: t.en.product_001_name, price: 7800, rating: 5.0, reviews: 109, badge: t.en.product_badge_hit, short: 'Steel 420 · 460/520 mm · 1.3 kg', desc: 'Nordic skates (also called bais). Open-ice skates of our own design and manufacture, intended for use with cross-country ski boots for skating. These skates are the result of long and meticulous work, both theoretically and in practical execution.', specs: [
      { k: 'Steel', v: '420 stainless, 2 mm' }, { k: 'Frame', v: 'Aluminum angle 20×20×2 mm' }, { k: 'Rivets', v: 'Solid aluminum' }, { k: 'Length', v: '460 mm / 520 mm' }, { k: 'Pair weight', v: '800 g (460 mm) / 880 g (520 mm)' }, { k: 'Packed weight', v: '1.3 kg' }, { k: 'Max load', v: 'up to 110 kg (reinforced — custom order)' }, { k: 'Binding shelf', v: '42 mm' }, { k: 'Turn radius', v: '4 m (460 mm) / 7 m (520 mm)' }, { k: 'Edge life', v: '≥ 200 km on clean ice' }, { k: 'Production', v: 'CNC laser cutting' }, { k: 'Compatibility', v: 'NNN, SNS, Prolink' },
    ], variants: { size: ['460 mm', '520 mm'], binding: ['NNN', 'SNS'] } },
    '002': { sku: '002', name: t.en.product_002_name, price: 9200, rating: 5.0, reviews: 109, badge: t.en.product_badge_hit, short: 'Anti-corrosion coating · steel 420 · 460/520 mm', desc: 'Premium version with powder anti-corrosion coating. Same reliability as unpainted, plus rust protection and a stylish look.', specs: [
      { k: 'Steel', v: '420 stainless, 2 mm' }, { k: 'Coating', v: 'Powder coating' }, { k: 'Length', v: '460 mm / 520 mm' }, { k: 'Pair weight', v: '800 g (460 mm) / 880 g (520 mm)' }, { k: 'Packed weight', v: '1.3 kg' }, { k: 'Max load', v: 'up to 110 kg' }, { k: 'Edge life', v: '≥ 200 km' },
    ], variants: { size: ['460 mm', '520 mm'], binding: ['NNN', 'SNS'] } },
    '003': { sku: '003', name: t.en.product_003_name, price: 6600, rating: null, reviews: 0, badge: null, short: '480/520 mm · 1.1 kg', desc: 'Steel blade for open ice. Suitable for self-installation on NNN and SNS ski boots.', specs: [
      { k: 'Material', v: 'Steel' }, { k: 'Length', v: '480 mm / 520 mm' }, { k: 'Weight', v: '1.1 kg' }, { k: 'Compatibility', v: 'NNN, SNS' },
    ], variants: { size: ['480 mm', '520 mm'] } },
    '004': { sku: '004', name: t.en.product_004_name, price: 8000, rating: null, reviews: 0, badge: null, short: 'Protective coating · 480/520 mm', desc: 'Blade with anti-corrosion coating. Longer service life, rust protection.', specs: [
      { k: 'Material', v: 'Steel' }, { k: 'Coating', v: 'Powder coating' }, { k: 'Length', v: '480 mm / 520 mm' }, { k: 'Weight', v: '1.1 kg' }, { k: 'Compatibility', v: 'NNN, SNS' },
    ], variants: { size: ['480 mm', '520 mm'] } },
    '005': { sku: '005', name: t.en.product_005_name, price: 1200, rating: null, reviews: 0, badge: t.en.product_badge_hit, short: 'Velvet furniture fabric', desc: 'Made of durable velvet furniture fabric with soft pleasant pile. Very convenient for storing and transporting lake skates from both our production and third-party models.', specs: [
      { k: 'Material', v: 'Velvet furniture fabric' }, { k: 'Weight', v: '0.1 kg' }, { k: 'Purpose', v: 'Storage and transport' },
    ] },
    '006': { sku: '006', name: t.en.product_006_name, price: 1200, rating: null, reviews: 0, badge: null, short: 'Metal supports · SNS/NNN · 0.35 kg', desc: 'The bearing parts of the binding head are made of metal, which increases its reliability compared to fully plastic analogues.', specs: [
      { k: 'Support material', v: 'Metal' }, { k: 'Type', v: 'Monolithic plate' }, { k: 'Weight', v: '0.35 kg' }, { k: 'Compatibility', v: 'NNN, SNS, Prolink' },
    ], variants: { binding: ['NNN', 'SNS'] } },
  },
  zh: {
    '001': { sku: '001', name: t.zh.product_001_name, price: 7800, rating: 5.0, reviews: 109, badge: t.zh.product_badge_hit, short: '420不锈钢 · 460/520毫米 · 1.3公斤', desc: '北欧冰鞋（也称为bais）。我们自主设计和制造的开放冰面冰鞋，配合越野滑雪靴滑冰使用。这些冰鞋是长期细致工作的成果，理论和实践执行俱佳。', specs: [
      { k: '钢材', v: '420不锈钢，2毫米' }, { k: '框架', v: '铝角20×20×2毫米' }, { k: '铆钉', v: '实心铝' }, { k: '长度', v: '460毫米 / 520毫米' }, { k: '成对重量', v: '800克 (460毫米) / 880克 (520毫米)' }, { k: '包装重量', v: '1.3公斤' }, { k: '最大载荷', v: '高达110公斤（加强版 — 定制）' }, { k: '绑定架', v: '42毫米' }, { k: '转弯半径', v: '4米 (460毫米) / 7米 (520毫米)' }, { k: '刀刃寿命', v: '洁净冰面≥200公里' }, { k: '生产', v: 'CNC激光切割' }, { k: '兼容性', v: 'NNN, SNS, Prolink' },
    ], variants: { size: ['460毫米', '520毫米'], binding: ['NNN', 'SNS'] } },
    '002': { sku: '002', name: t.zh.product_002_name, price: 9200, rating: 5.0, reviews: 109, badge: t.zh.product_badge_hit, short: '防腐涂层 · 420不锈钢 · 460/520毫米', desc: '带粉末防腐涂层的优质版本。与未涂装版本同样可靠，加上防锈保护和时尚外观。', specs: [
      { k: '钢材', v: '420不锈钢，2毫米' }, { k: '涂层', v: '粉末涂层' }, { k: '长度', v: '460毫米 / 520毫米' }, { k: '成对重量', v: '800克 (460毫米) / 880克 (520毫米)' }, { k: '包装重量', v: '1.3公斤' }, { k: '最大载荷', v: '高达110公斤' }, { k: '刀刃寿命', v: '≥200公里' },
    ], variants: { size: ['460毫米', '520毫米'], binding: ['NNN', 'SNS'] } },
    '003': { sku: '003', name: t.zh.product_003_name, price: 6600, rating: null, reviews: 0, badge: null, short: '480/520毫米 · 1.1公斤', desc: '适用于开放冰面的钢制冰刀。适合自行安装在NNN和SNS滑雪靴上。', specs: [
      { k: '材料', v: '钢' }, { k: '长度', v: '480毫米 / 520毫米' }, { k: '重量', v: '1.1公斤' }, { k: '兼容性', v: 'NNN, SNS' },
    ], variants: { size: ['480毫米', '520毫米'] } },
    '004': { sku: '004', name: t.zh.product_004_name, price: 8000, rating: null, reviews: 0, badge: null, short: '保护涂层 · 480/520毫米', desc: '带防腐涂层的冰刀。使用寿命更长，防锈保护。', specs: [
      { k: '材料', v: '钢' }, { k: '涂层', v: '粉末涂层' }, { k: '长度', v: '480毫米 / 520毫米' }, { k: '重量', v: '1.1公斤' }, { k: '兼容性', v: 'NNN, SNS' },
    ], variants: { size: ['480毫米', '520毫米'] } },
    '005': { sku: '005', name: t.zh.product_005_name, price: 1200, rating: null, reviews: 0, badge: t.zh.product_badge_hit, short: '绒面家具布料', desc: '由坚固的绒面家具布料制成，绒毛柔软舒适。便于存放和运输我们生产的湖上冰鞋以及第三方型号。', specs: [
      { k: '材料', v: '绒面家具布料' }, { k: '重量', v: '0.1公斤' }, { k: '用途', v: '存储和运输' },
    ] },
    '006': { sku: '006', name: t.zh.product_006_name, price: 1200, rating: null, reviews: 0, badge: null, short: '金属支架 · SNS/NNN · 0.35公斤', desc: '绑定头部的承重部件由金属制成，比全塑料同类产品更可靠。', specs: [
      { k: '支架材料', v: '金属' }, { k: '类型', v: '整体板' }, { k: '重量', v: '0.35公斤' }, { k: '兼容性', v: 'NNN, SNS, Prolink' },
    ], variants: { binding: ['NNN', 'SNS'] } },
  },
};

const reviewsData: Record<Lang, Array<{ name: string; city: string; text: string }>> = {
  ru: [
    { name: 'Антон', city: 'Иркутск', text: 'Откатал за сезон порядка 700 км, не точил. Лишний вес, нулевая физподготовка. Коньки практически едут сами.' },
    { name: 'Алексей', city: 'Москва', text: 'Прекрасная обработка металла, прекрасная форма лезвий. Продавец объяснил всё по установке.' },
    { name: 'Михаил', city: 'Ангарск', text: 'Очень лёгкие байсы, продавец порядочный, рекомендую.' },
  ],
  en: [
    { name: 'Anton', city: 'Irkutsk', text: 'Rode about 700 km in a season, never sharpened. Extra weight, zero fitness. The skates practically go by themselves.' },
    { name: 'Alexey', city: 'Moscow', text: 'Excellent metalwork, excellent blade shape. The seller explained everything about installation.' },
    { name: 'Mikhail', city: 'Angarsk', text: 'Very light bais, honest seller, recommend.' },
  ],
  zh: [
    { name: 'Anton', city: '伊尔库茨克', text: '一个赛季骑了大约700公里，从未磨刃。超重，零体能。冰鞋几乎自己跑。' },
    { name: 'Alexey', city: '莫斯科', text: '金属加工精良，冰刀形状优秀。卖家详细解释了安装事宜。' },
    { name: 'Mikhail', city: '安加尔斯克', text: '非常轻便的冰鞋，诚实的卖家，推荐。' },
  ],
};

const labels = {
  ru: { home: 'Главная', catalog: 'Каталог', article: 'Арт.', reviewsCount: (n: number, r: number) => `${n} ОТЗЫВОВ · ${r}`, size: 'Размер', chooseSize: 'Выбрать размер', binding: 'Крепление', chooseBinding: 'Выбрать тип', orderMax: '⚡ Заказать в MAX', back: '← В каталог', desc: 'Описание', specs: 'Характеристики', reviewsLabel: (r: number) => `★ ★ ★ ★ ★ · 5.0 · ${r} отзывов`, reviews: 'Отзывы', ready: 'Готов заказать?', priceLinePrefix: 'Цена:', priceLineSuffix: '· Доставка по РФ 3–7 дней · Гарантия 1 год' },
  en: { home: 'Home', catalog: 'Catalog', article: 'Art.', reviewsCount: (n: number, r: number) => `${n} REVIEWS · ${r}`, size: 'Size', chooseSize: 'Choose size', binding: 'Binding', chooseBinding: 'Choose type', orderMax: '⚡ Order via MAX', back: '← To catalog', desc: 'Description', specs: 'Specifications', reviewsLabel: (r: number) => `★ ★ ★ ★ ★ · 5.0 · ${r} reviews`, reviews: 'Reviews', ready: 'Ready to order?', priceLinePrefix: 'Price:', priceLineSuffix: '· Shipping across Russia 3–7 days · 1-year warranty' },
  zh: { home: '首页', catalog: '目录', article: '货号', reviewsCount: (n: number, r: number) => `${n}条评价 · ${r}`, size: '尺寸', chooseSize: '选择尺寸', binding: '绑定类型', chooseBinding: '选择类型', orderMax: '⚡ 在MAX中订购', back: '← 返回目录', desc: '描述', specs: '规格', reviewsLabel: (r: number) => `★ ★ ★ ★ ★ · 5.0 · ${r}条评价`, reviews: '用户评价', ready: '准备订购？', priceLinePrefix: '价格:', priceLineSuffix: '· 俄罗斯全境配送3–7天 · 1年质保' },
} as const;
const L = labels[lang];

const sku = Astro.params.sku as string;
const p = products[lang][sku];
if (!p) return Astro.redirect('/catalog');
---
<Base title={`${p.name.toUpperCase()} · GROM`} description={`${p.name} — ${p.specs[0]?.v || 'Сталь 420'}. ${lang === 'ru' ? 'Озёрные коньки ГРОМ. Доставка по РФ.' : lang === 'en' ? 'GROM lake skates. Ships across Russia.' : 'ГРОМ 冰刀。全俄配送。'}`}>

  <!-- Schema.org Product -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": p.name,
    "description": p.desc,
    "image": `https://11111000000.github.io/gromproject/photos/${p.sku}.jpg`,
    "sku": p.sku,
    "brand": { "@type": "Brand", "name": "ГРОМ" },
    "manufacturer": { "@type": "Organization", "name": "ООО «ГРОМ»", "address": { "@type": "PostalAddress", "addressLocality": "Ангарск", "addressCountry": "RU" } },
    "offers": {
      "@type": "Offer",
      "price": p.price,
      "priceCurrency": "RUB",
      "availability": "https://schema.org/InStock",
      "seller": { "@type": "Organization", "name": "ГРОМ" }
    },
    ...(p.rating ? { "aggregateRating": { "@type": "AggregateRating", "ratingValue": p.rating, "reviewCount": p.reviews, "bestRating": 5 } } : {}),
    "additionalProperty": p.specs.map(s => ({ "@type": "PropertyValue", "name": s.k, "value": s.v }))
  })} />

  <!-- Schema.org BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": lang === 'ru' ? 'Главная' : lang === 'en' ? 'Home' : '首页', "item": "https://11111000000.github.io/gromproject/" },
      { "@type": "ListItem", "position": 2, "name": lang === 'ru' ? 'Каталог' : lang === 'en' ? 'Catalog' : '目录', "item": "https://11111000000.github.io/gromproject/catalog/" },
      { "@type": "ListItem", "position": 3, "name": p.name }
    ]
  })} />

  <section class="relative bg-thunder text-frost py-12 sm:py-16 overflow-hidden border-b-4 border-bolt">
    <div class="absolute inset-0 bg-ice-texture opacity-90"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-xs font-mono uppercase tracking-industrial text-frost/50 mb-6">
        <a href={`${import.meta.env.BASE_URL}/`} class="hover:text-bolt">{L.home}</a> ·
        <a href={`${import.meta.env.BASE_URL}/catalog`} class="hover:text-bolt">{L.catalog}</a> ·
        <span class="text-frost">{p.name}</span>
      </nav>
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-start">
        <div class="relative aspect-square bg-ice-texture overflow-hidden border-2 border-bolt/40">
          <ProductImage sku={p.sku} name={p.name} class="absolute inset-0" loading="eager" size="hero" />
          {p.badge && <div class="badge-bolt absolute top-4 right-4 z-10">{p.badge}</div>}
        </div>

